{
  "name": "workshop-management-system",
  "version": "1.0.0",
  "private": true,
  "description": "Complete Fleet & Workshop Management System",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
